#!/usr/bin/env bash
# avad-review-log — atomically log a review result
# Usage: avad-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/avad-slug" 2>/dev/null)"
AVAD_HOME="${AVAD_HOME:-$HOME/.avad}"
mkdir -p "$AVAD_HOME/projects/$SLUG"
echo "$1" >> "$AVAD_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
