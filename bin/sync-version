#!/usr/bin/env bash
# sync-version — reads VERSION and patches package.json + plugin.json
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

VERSION_FILE="$ROOT/VERSION"
PACKAGE_JSON="$ROOT/package.json"
PLUGIN_JSON="$ROOT/.claude-plugin/plugin.json"

if [[ ! -f "$VERSION_FILE" ]]; then
  echo "ERROR: $VERSION_FILE not found" >&2
  exit 1
fi

VER="$(tr -d '[:space:]' < "$VERSION_FILE")"

if [[ -z "$VER" ]]; then
  echo "ERROR: VERSION file is empty" >&2
  exit 1
fi

update_json_version() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    echo "SKIP: $file not found" >&2
    return
  fi
  sed -i '' "s/\"version\": *\"[^\"]*\"/\"version\": \"$VER\"/" "$file"
  echo "  $file → $VER"
}

echo "Syncing version: $VER"
update_json_version "$PACKAGE_JSON"
update_json_version "$PLUGIN_JSON"
echo "Done."
